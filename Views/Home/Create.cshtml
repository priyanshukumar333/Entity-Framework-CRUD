@model EntityFrame.Models.Student

@{
    ViewData["Title"] = "Create";
}

<h1>Insert Database </h1>
@if (TempData["message"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <strong>Holy guacamole!</strong> @TempData["message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["success"] != null)
{
    <div class="alert alert-warning alert-success fade show" role="alert">
        <strong>Holy guacamole!</strong> @TempData["success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
<h4>Student</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Roll" class="control-label"></label>
                <input asp-for="Roll" class="form-control" />
                <span asp-validation-for="Roll" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="StuName" class="control-label"></label>
                <input asp-for="StuName" class="form-control" />
                <span asp-validation-for="StuName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="StuGender" class="control-label"></label>
                <input asp-for="StuGender" class="form-control" />
                <span asp-validation-for="StuGender" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="StuDob" class="control-label"></label>
                <input asp-for="StuDob" class="form-control" />
                <span asp-validation-for="StuDob" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="StuPhone" class="control-label"></label>
                <input asp-for="StuPhone" class="form-control" />
                <span asp-validation-for="StuPhone" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="StuBook" class="control-label"></label>
                <input asp-for="StuBook" class="form-control" />
                <span asp-validation-for="StuBook" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary mt-3" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="List">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
