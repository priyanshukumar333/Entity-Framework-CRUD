@model EntityFrame.Models.Student

@{
    ViewData["Title"] = "Delete";
}
@if (TempData["message"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <strong>message:</strong> @TempData["message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["success"] != null)
{
    <div class="alert alert-warning alert-success fade show" role="alert">
        <strong>message:</strong> @TempData["success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<h1>Delete Data</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Student</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Id)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Roll)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.StuName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.StuName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.StuGender)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.StuGender)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.StuDob)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.StuDob)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.StuPhone)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.StuPhone)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.StuBook)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.StuBook)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Roll" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="List">Back to List</a>
    </form>
</div>
